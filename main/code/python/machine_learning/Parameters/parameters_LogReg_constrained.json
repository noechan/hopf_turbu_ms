{
  "TEST_SIZE": 0.25,
  "DO_KFOLD_TEST": true,
  "RANDOM_STATE": 2,
  "VERBOSE": 0,
  "GROUPS": {
    "MCI_ABneg": 0,
    "MCI_ABpos": 1
  },
  "ID_KEY" : "PTID",
